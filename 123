-- ===== CONFIG =====
local CONFIG = {
    TweenSpeed = 0.1,
    OrbRange = 300,
    OrbTweenSpeed = 0.1,
    CustomDifficulty = nil, -- ใส่ตัวเลขเพื่อล็อค difficulty เช่น 9999 หรือใส่ nil เพื่อใช้ค่าจากเกม
}

-- ===== SERVICES =====
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

-- ===== STEP 1: GET DIFFICULTY =====
local function getDifficulty()
    -- ถ้าตั้ง CustomDifficulty ไว้ให้ใช้ค่านั้นเลย
    if CONFIG.CustomDifficulty then
        print("[Raid] Using custom difficulty: " .. CONFIG.CustomDifficulty)
        return CONFIG.CustomDifficulty
    end

    -- ไม่ได้ตั้งไว้ให้อ่านจากเกมตามปกติ
    local gui = Players.LocalPlayer.PlayerGui
    local text = gui.RaidSide.Frame.Top.Title.Text
    local level = tonumber(text:match("Raid Level (%d+)"))
    if level then
        print("[Raid] Difficulty found: " .. level)
        return level
    else
        warn("[Raid] Could not parse difficulty from: " .. tostring(text))
        return nil
    end
end

-- ===== STEP 1: FIND AVAILABLE PORTAL =====
local function findAvailablePortal()
    local success, portals = pcall(function()
        return workspace.__THINGS.__INSTANCE_CONTAINER.Active.LuckyEventWorld.INTERACT.RaidPortals
    end)
    if not success or not portals then
        warn("[Raid] LuckyEventWorld not found, not in zone yet...")
        return nil
    end

    for i = 1, 10 do
        local portal = portals[tostring(i)]
        if portal then
            local ok, enabled = pcall(function()
                return portal.Billboard.BillboardGui.Enabled
            end)
            if ok then
                if not enabled then
                    print("[Raid] Portal " .. i .. " is available ✓")
                    return i
                else
                    print("[Raid] Portal " .. i .. " is occupied, skipping...")
                end
            else
                print("[Raid] Portal " .. i .. " could not be read, skipping...")
            end
        else
            print("[Raid] Portal " .. i .. " does not exist, skipping...")
        end
    end
    warn("[Raid] No available portals found!")
    return nil
end

-- ===== STEP 1: CREATE OWN RAID (retry until success) =====
local function createOwnRaid()
    print("[Raid] ===== Step 1: Creating Raid =====")
    while true do
        -- ดึง difficulty ใหม่ทุกรอบ
        local difficulty = getDifficulty()
        if not difficulty then
            warn("[Raid] Could not get difficulty, retrying in 3s...")
            task.wait(3)
            continue
        end

        -- สแกนหาประตูว่างใหม่ทุกรอบ
        local portalIndex = findAvailablePortal()
        if not portalIndex then
            warn("[Raid] No available portal, retrying in 3s...")
            task.wait(3)
            continue
        end

        print("[Raid] Invoking Raids_Init with Difficulty=" .. difficulty .. ", Portal=" .. portalIndex)
        local success, result = pcall(function()
            return ReplicatedStorage.Network.Raids_Init:InvokeServer({
                ["Difficulty"] = difficulty,
                ["Portal"] = portalIndex,
                ["PartyMode"] = 1
            })
        end)

        if success and result then
            print("[Raid] Raid created successfully! Result: " .. tostring(result))
            return portalIndex
        else
            warn("[Raid] InvokeServer failed: " .. tostring(result) .. ", retrying in 3s...")
            task.wait(3)
            -- วนกลับไปดึง difficulty และ portal ใหม่อีกรอบ
        end
    end
end

-- ===== STEP 2: TWEEN TO PORTAL (retry until success) =====
local function tweenToPortal(portalIndex)
    print("[Raid] ===== Step 2: Teleporting to Portal =====")
    while true do
        local character = Players.LocalPlayer.Character or Players.LocalPlayer.CharacterAdded:Wait()
        local hrp = character:WaitForChild("HumanoidRootPart")

        local portals = workspace.__THINGS.__INSTANCE_CONTAINER.Active.LuckyEventWorld.INTERACT.RaidPortals
        local enterPart
        local success = pcall(function()
            enterPart = portals[tostring(portalIndex)].Enter
        end)

        if not success or not enterPart then
            warn("[Raid] Enter part not found for portal " .. portalIndex .. ", retrying in 3s...")
            task.wait(3)
            continue
        end

        print("[Raid] Tweening to Portal " .. portalIndex .. " Enter part (Speed: " .. CONFIG.TweenSpeed .. "s)...")
        local tweenInfo = TweenInfo.new(CONFIG.TweenSpeed, Enum.EasingStyle.Linear, Enum.EasingDirection.In, -1)
        local tween = TweenService:Create(hrp, tweenInfo, { CFrame = enterPart.CFrame })
        tween:Play()
        print("[Raid] Tween started, waiting for Enter part to disappear...")

        enterPart.AncestryChanged:Connect(function()
            if not enterPart:IsDescendantOf(workspace) then
                tween:Cancel()
            end
        end)

        repeat task.wait(0.1) until not enterPart:IsDescendantOf(workspace)
        tween:Cancel()
        print("[Raid] Successfully entered Portal " .. portalIndex .. " ✓")
        return true
    end
end

-- ===== HELPER: GET HRP =====
local function getHRP()
    local character = Players.LocalPlayer.Character or Players.LocalPlayer.CharacterAdded:Wait()
    return character:WaitForChild("HumanoidRootPart")
end

-- ===== HELPER: GET MODEL POSITION =====
local function getModelPosition(model)
    if model.PrimaryPart then
        return model.PrimaryPart.Position
    end
    for _, part in pairs(model:GetDescendants()) do
        if part:IsA("BasePart") then
            return part.Position
        end
    end
    return nil
end

-- ===== HELPER: TWEEN TO TARGET แล้วค้างไว้ =====
local function tweenToTarget(hrp, getTargetCFrame, isGone)
    local running = true
    task.spawn(function()
        while running do
            local tween = TweenService:Create(hrp, TweenInfo.new(CONFIG.TweenSpeed, Enum.EasingStyle.Linear), {
                CFrame = getTargetCFrame()
            })
            tween:Play()
            task.wait(CONFIG.TweenSpeed)
        end
    end)
    repeat task.wait(0.1) until isGone()
    running = false
    print("[Raid] Target gone, stopping tween ✓")
end

-- ===== HELPER: หา orb ที่ใกล้ที่สุด =====
local function getNearestOrb(hrp)
    local orbContainer = workspace.__THINGS.Orbs
    local nearest = nil
    local nearestDist = math.huge
    for _, obj in pairs(orbContainer:GetChildren()) do
        if (obj:IsA("MeshPart") or obj:IsA("BasePart")) and obj:IsDescendantOf(workspace) then
            local dist = (obj.Position - hrp.Position).Magnitude
            if dist <= CONFIG.OrbRange and dist < nearestDist then
                nearest = obj
                nearestDist = dist
            end
        end
    end
    return nearest, nearestDist
end

-- ===== STEP 3: COLLECT ALL ORBS =====
local function collectAllOrbs(hrp)
    while true do
        local orb, dist = getNearestOrb(hrp)
        if not orb then break end
        print("[Raid] [ORB] Collecting orb at distance " .. math.floor(dist) .. " studs...")
        tweenToTarget(
            hrp,
            function()
                if orb and orb:IsDescendantOf(workspace) then
                    return orb.CFrame
                end
                return hrp.CFrame
            end,
            function()
                return not orb:IsDescendantOf(workspace)
            end
        )
        print("[Raid] [ORB] Orb collected ✓")
        task.wait(0.05)
    end
    print("[Raid] [ORB] No more orbs nearby ✓")
end

-- ===== STEP 3: BREAK BOXES (Orb priority) =====
local function breakBoxes()
    print("[Raid] ===== Step 3: Breaking Boxes =====")
    local hrp = getHRP()
    local lastBreakableTime = tick()

    while true do
        local orb = getNearestOrb(hrp)
        if orb then
            print("[Raid] [ORB] Orb detected before targeting box, collecting first...")
            collectAllOrbs(hrp)
        end

        local breakables = workspace.__THINGS.Breakables
        local models = {}
        for _, obj in pairs(breakables:GetChildren()) do
            if obj:IsA("Model") then
                local pos = getModelPosition(obj)
                if pos then
                    local dist = (pos - hrp.Position).Magnitude
                    table.insert(models, {model = obj, pos = pos, dist = dist})
                end
            end
        end

        if #models == 0 then
            if tick() - lastBreakableTime >= 5 then
                print("[Raid] No breakables for 5 seconds, proceeding to boss fight ✓")
                break
            end
            task.wait(0.1)
            continue
        end

        lastBreakableTime = tick()
        table.sort(models, function(a, b) return a.dist < b.dist end)
        local nearest = models[1]
        local targetModel = nearest.model
        print("[Raid] Targeting nearest breakable: " .. targetModel.Name .. " (dist: " .. math.floor(nearest.dist) .. " studs)")

        local interrupted = false
        tweenToTarget(
            hrp,
            function()
                if targetModel and targetModel.PrimaryPart then
                    return targetModel.PrimaryPart.CFrame
                end
                return hrp.CFrame
            end,
            function()
                if not targetModel:IsDescendantOf(workspace) then
                    return true
                end
                local nearOrb = getNearestOrb(hrp)
                if nearOrb then
                    print("[Raid] [ORB] Orb detected while breaking box! Interrupting...")
                    interrupted = true
                    return true
                end
                return false
            end
        )

        if interrupted then
            collectAllOrbs(hrp)
        else
            print("[Raid] Breakable destroyed ✓")
            lastBreakableTime = tick()
            collectAllOrbs(hrp)
        end

        task.wait(0.05)
    end

    collectAllOrbs(hrp)
end

-- ===== STEP 4: WAIT FOR BOSS MODEL =====
local function waitForBossModel(timeoutSeconds)
    local breakables = workspace.__THINGS.Breakables
    local startTime = tick()
    while tick() - startTime < timeoutSeconds do
        for _, obj in pairs(breakables:GetChildren()) do
            if obj:IsA("Model") then
                return obj
            end
        end
        task.wait(0.1)
    end
    return nil
end

-- ===== STEP 4: FIGHT BOSS =====
local function fightBoss(bossIndex)
    print("[Raid] [BOSS] Invoking BossChallenge for Boss " .. bossIndex .. "...")

    local success, result = pcall(function()
        return ReplicatedStorage.Network.Raids_BossChallenge:InvokeServer(bossIndex)
    end)

    if not success then
        warn("[Raid] [BOSS] InvokeServer failed: " .. tostring(result))
        return false
    end
    print("[Raid] [BOSS] Remote fired, Result: " .. tostring(result))

    print("[Raid] [BOSS] Waiting for Boss " .. bossIndex .. " to spawn (attempt 1)...")
    local bossModel = waitForBossModel(2)

    if not bossModel then
        print("[Raid] [BOSS] Boss not found, retrying remote (attempt 2)...")
        pcall(function()
            ReplicatedStorage.Network.Raids_BossChallenge:InvokeServer(bossIndex)
        end)
        print("[Raid] [BOSS] Waiting for Boss " .. bossIndex .. " to spawn (attempt 2)...")
        bossModel = waitForBossModel(2)
    end

    if not bossModel then
        warn("[Raid] [BOSS] Boss " .. bossIndex .. " did not spawn after 2 attempts, skipping...")
        return false
    end

    print("[Raid] [BOSS] Boss " .. bossIndex .. " found: " .. bossModel.Name .. ", tweening...")
    local hrp = getHRP()

    while bossModel:IsDescendantOf(workspace) do
        local interrupted = false
        tweenToTarget(
            hrp,
            function()
                if bossModel and bossModel.PrimaryPart then
                    return bossModel.PrimaryPart.CFrame
                end
                return hrp.CFrame
            end,
            function()
                if not bossModel:IsDescendantOf(workspace) then
                    return true
                end
                local nearOrb = getNearestOrb(hrp)
                if nearOrb then
                    print("[Raid] [ORB] Orb detected while fighting boss! Interrupting...")
                    interrupted = true
                    return true
                end
                return false
            end
        )
        if interrupted then
            collectAllOrbs(hrp)
        end
    end

    collectAllOrbs(hrp)
    print("[Raid] [BOSS] Boss " .. bossIndex .. " defeated ✓")
    return true
end

-- ===== STEP 4: FIGHT ALL BOSSES =====
local function fightAllBosses()
    print("[Raid] ===== Step 4: Boss Fight =====")
    for i = 1, 3 do
        print("[Raid] [BOSS] Starting Boss " .. i .. "...")
        fightBoss(i)
        task.wait(0.5)
    end
    print("[Raid] [BOSS] All bosses done ✓")
end

-- ===== STEP 5: OPEN CHESTS =====
local function openChests()
    print("[Raid] ===== Step 5: Opening Chests =====")
    local hrp = getHRP()
    local interactPath = workspace.__THINGS.__INSTANCE_CONTAINER.Active.LuckyRaid.INTERACT

    local chestNames = {
        "LootChest",
        "HugeChest",
        "TitanicChest",
        "Tier1000Chest",
    }

    for _, chestName in pairs(chestNames) do
        local chestFolder = interactPath[chestName]
        if not chestFolder then
            print("[Raid] [CHEST] " .. chestName .. " not found, skipping...")
            continue
        end

        local chestParts = {}
        for _, obj in pairs(chestFolder:GetChildren()) do
            if obj:IsA("BasePart") or obj:IsA("MeshPart") or obj:IsA("Model") then
                table.insert(chestParts, obj)
            end
        end

        if #chestParts == 0 then
            print("[Raid] [CHEST] " .. chestName .. " has no interactable parts, skipping...")
            continue
        end

        print("[Raid] [CHEST] Opening " .. chestName .. " (" .. #chestParts .. " chest(s))...")

        for _, chestObj in pairs(chestParts) do
            if not chestObj:IsDescendantOf(workspace) then continue end

            local targetCFrame
            if chestObj:IsA("Model") then
                if chestObj.PrimaryPart then
                    targetCFrame = chestObj.PrimaryPart.CFrame
                else
                    for _, p in pairs(chestObj:GetDescendants()) do
                        if p:IsA("BasePart") then
                            targetCFrame = p.CFrame
                            break
                        end
                    end
                end
            else
                targetCFrame = chestObj.CFrame
            end

            if not targetCFrame then continue end

            print("[Raid] [CHEST] Tweening to " .. chestName .. "...")

            local running = true
            task.spawn(function()
                while running do
                    local tween = TweenService:Create(hrp, TweenInfo.new(CONFIG.TweenSpeed, Enum.EasingStyle.Linear), {
                        CFrame = targetCFrame
                    })
                    tween:Play()
                    task.wait(CONFIG.TweenSpeed)
                end
            end)

            repeat
                task.wait(0.05)
            until (hrp.Position - targetCFrame.Position).Magnitude <= 5 or not chestObj:IsDescendantOf(workspace)

            running = false

            if not chestObj:IsDescendantOf(workspace) then
                print("[Raid] [CHEST] " .. chestName .. " already gone, skipping...")
                continue
            end

            print("[Raid] [CHEST] Pressing E to open " .. chestName .. "...")
            keypress(0x45)
            task.wait(0.1)
            keyrelease(0x45)
            task.wait(0.3)

            print("[Raid] [CHEST] " .. chestName .. " opened ✓")
        end
    end

    print("[Raid] [CHEST] All chests opened ✓")
    task.wait(0.5)
    collectAllOrbs(hrp)
end

-- ===== STEP 6: EXIT RAID =====
local function exitRaid()
    print("[Raid] ===== Step 6: Exiting Raid =====")
    local hrp = getHRP()

    local enterTeleport = workspace.__THINGS.Instances.LuckyEgg.Teleports.Enter
    print("[Raid] Tweening to LuckyEgg Enter teleport...")
    local running = true
    task.spawn(function()
        while running do
            local tween = TweenService:Create(hrp, TweenInfo.new(CONFIG.TweenSpeed, Enum.EasingStyle.Linear), {
                CFrame = enterTeleport.CFrame
            })
            tween:Play()
            task.wait(CONFIG.TweenSpeed)
        end
    end)
    repeat task.wait(0.05) until (hrp.Position - enterTeleport.Position).Magnitude <= 5
    running = false
    print("[Raid] Reached Enter teleport ✓")

    print("[Raid] Waiting 5 seconds for map to load...")
    task.wait(5)

    local leaveTeleport = workspace.__THINGS.Instances.LuckyEgg.Teleports.Leave
    print("[Raid] Tweening to LuckyEgg Leave teleport...")
    running = true
    task.spawn(function()
        while running do
            local tween = TweenService:Create(hrp, TweenInfo.new(CONFIG.TweenSpeed, Enum.EasingStyle.Linear), {
                CFrame = leaveTeleport.CFrame
            })
            tween:Play()
            task.wait(CONFIG.TweenSpeed)
        end
    end)
    repeat task.wait(0.05) until (hrp.Position - leaveTeleport.Position).Magnitude <= 5
    running = false
    print("[Raid] Reached Leave teleport ✓")

    print("[Raid] Waiting 3 seconds before next raid...")
    task.wait(3)
    print("[Raid] Ready for next raid ✓")
end

-- ===== ANTI DOUBLE RUN =====
if _G.RaidBotRunning then
    warn("[Raid] Bot is already running! Stopping duplicate.")
    return
end
_G.RaidBotRunning = true

-- ===== MAIN LOOP =====
local raidCount = 0
local success, err = pcall(function()
    while true do
        raidCount = raidCount + 1
        print("[Raid] ========== RAID #" .. raidCount .. " START ==========")

        local portalIndex = createOwnRaid()
        if portalIndex then
            task.wait(1)
            local entered = tweenToPortal(portalIndex)
            if entered then
                print("[Raid] Waiting for raid to load...")
                repeat
                    task.wait(0.5)
                until (function()
                    for _, obj in pairs(workspace.__THINGS.Breakables:GetChildren()) do
                        if obj:IsA("Model") then return true end
                    end
                    return false
                end)()
                print("[Raid] Raid loaded ✓")
                breakBoxes()
                fightAllBosses()
                openChests()
            end
        end

        exitRaid()
        print("[Raid] ========== RAID #" .. raidCount .. " COMPLETE ==========")
    end
end)

-- ===== CLEANUP =====
_G.RaidBotRunning = false
if err then
    warn("[Raid] Bot stopped with error: " .. tostring(err))
else
    print("[Raid] Bot stopped.")
end
