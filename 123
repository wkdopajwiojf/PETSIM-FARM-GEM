-- [[ ANTI DOUBLE-RUN CHECK ]]
if _G.LuckyRaidStarted then 
    warn("[System] Script is already running!")
    return 
end
_G.LuckyRaidStarted = true

local TweenService = game:GetService("TweenService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Network = ReplicatedStorage:WaitForChild("Network")
local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local LocalPlayer = Players.LocalPlayer

-- [[ CONFIGURATION ]]
local Config = {
    TweenSpeed = 400,            
	MaxOrbDistance = 1300,
	MaxOrbHeightDiff = 100,
    PortalTweenSpeed = 150,      
    LeaveTweenSpeed = 60,       
    MaxFarmDistance = 1750,       
    WaitBeforeTween = 0.5,
    DoubleCheckDistance = 20,    -- ระยะที่ถ้า "ใกล้กว่า 20" ให้ Tween ซ้ำเพื่อย้ำจุดวาร์ป
    BossNames = {"Boss1", "Boss2", "Boss3"},
    Chests = {"Tier1000Chest", "LootChest", "TitanicChest", "HugeChest"}
}

-- [[ UTILS ]]
local function getRoot()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    return char:WaitForChild("HumanoidRootPart")
end

-- ฟังก์ชัน Tween แบบ "กดย้ำ" เมื่อถึงจุดวาร์ป
local function forceTween(targetCFrame, speedOverride, isWarpPoint)
    local root = getRoot()
    if not root then return end
    
    local speed = speedOverride or Config.TweenSpeed
    
    local function executeTween()
        local distance = (root.Position - targetCFrame.Position).Magnitude
        if distance < 1 then return end -- ใกล้มากแล้วไม่ต้องทำอะไร

        local duration = distance / speed
        local tween = TweenService:Create(root, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
        
        tween:Play()
        
        local t = 0
        while (root.Position - targetCFrame.Position).Magnitude > 1 and t < duration + 0.1 do
            task.wait(0.05)
            t = t + 0.05
        end
        tween:Cancel()
    end

    -- รันรอบแรกปกติ
    executeTween()

    -- [[ THE "DOUBLE TAP" LOGIC ]]
    -- ถ้าเป็นจุดวาร์ป (Portal, Enter, Leave) และเราอยู่ใกล้เป้าหมาย < 20 studs
    if isWarpPoint then
        local currentDist = (root.Position - targetCFrame.Position).Magnitude
        if currentDist <= Config.DoubleCheckDistance then
            print("[System] Already near warp point, performing Re-Tween to ensure trigger...")
            task.wait(0.1)
            executeTween() -- Tween ย้ำเข้าไปที่จุดเดิมอีกรอบเพื่อให้มันวาร์ป
        end
    end
end

-- [[ IMPROVED ORB COLLECTION ]]
local function collectOrbs()
    local root = getRoot()
    if not root then return false end
    
    local orbs = workspace.__THINGS:FindFirstChild("Orbs")
    if not orbs then return false end
    
    local acted = false
    local allOrbs = orbs:GetChildren()
    
    for _, orb in pairs(allOrbs) do
        if orb:IsA("BasePart") then
            local orbPos = orb.Position
            local dist = (root.Position - orbPos).Magnitude
            local heightDiff = math.abs(root.Position.Y - orbPos.Y)
            
            -- [CHECK] ต้องอยู่ในระยะที่กำหนด และ ความสูงไม่ต่างกันเกินไป
            if dist <= Config.MaxOrbDistance and heightDiff <= Config.MaxOrbHeightDiff then
                -- ใช้ Tween ปกติ (ไม่ต้อง Precision เพราะไม่ใช่จุดวาร์ป)
                forceTween(orb.CFrame)
                
                -- ยิง Remote เก็บ Orb
                local remote = Network:FindFirstChild("Orbs_Collect") or Network:FindFirstChild("Orbs: Collect")
                if remote then 
                    remote:FireServer(orb.Name) 
                end
                
                orb:Destroy()
                acted = true
                
                -- พักนิดนึงเพื่อให้ Server ทัน (ลดโอกาสโดนเตะ หรือสคริปต์ค้าง)
                task.wait(0.01) 
            end
        end
    end
    return acted
end

-- [[ PRECISION WARP (คงเดิมตามความแม่นยำ 100%) ]]
local function precisionWarp(targetCFrame, speedOverride)
    local root = getRoot()
    if not root then return end
    
    local speed = speedOverride or Config.TweenSpeed
    
    -- 1. วิ่งไปรอบแรก
    local dist = (root.Position - targetCFrame.Position).Magnitude
    local duration = dist / speed
    local t = TweenService:Create(root, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
    t:Play()
    t.Completed:Wait()

    -- 2. ระบบ Micro-Wiggle ย้ำ 3 รอบ (เพื่อให้เข้าประตูแน่ๆ)
    for i = 1, 3 do
        if (root.Position - targetCFrame.Position).Magnitude < Config.WarpCheckDistance then
            root.CFrame = targetCFrame * CFrame.new(0, 0, 0.1) 
            task.wait(0.05)
            root.CFrame = targetCFrame * CFrame.new(0, 0, -0.1)
            task.wait(0.05)
            local quick = TweenService:Create(root, TweenInfo.new(0.1), {CFrame = targetCFrame})
            quick:Play()
            quick.Completed:Wait()
        end
    end
end

-- ฟังก์ชันกด E
local function pressE()
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    task.wait(0.2)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
end

-- [[ LOGIC 1 & 2: WORLD NAVIGATION ]]
local function findEmptyPortal()
    local activePath = workspace.__THINGS.__INSTANCE_CONTAINER:FindFirstChild("Active")
    local worldPath = activePath and activePath:FindFirstChild("LuckyEventWorld")
    if not worldPath then return nil end
    local portalsPath = worldPath.INTERACT.RaidPortals
    for i = 1, 10 do
        local portal = portalsPath:FindFirstChild(tostring(i))
        if portal then
            local billboardGui = portal:FindFirstChild("Billboard") and portal.Billboard:FindFirstChild("BillboardGui")
            if billboardGui and billboardGui.Enabled == false then return i end
        end
    end
    return nil
end

local function getRaidLevel()
    local success, result = pcall(function()
        local titleText = LocalPlayer.PlayerGui.RaidSide.Frame.Top.Title.Text
        local level = string.match(titleText, "Raid Level%s+(%d+)")
        return tonumber(level)
    end)
    return success and result or nil
end

-- [[ LOGIC 3 & 4: RAID GAMEPLAY ]]
local function farmNearestInRoom()
    local breakablesFolder = workspace.__THINGS:FindFirstChild("Breakables")
    if not breakablesFolder then return false end
    local target = nil
    local minSharedDist = 500 
    for _, v in pairs(breakablesFolder:GetChildren()) do
        local pos = v:IsA("Model") and v:GetModelCFrame() or (v:IsA("BasePart") and v.CFrame)
        if pos then
            local dist = (getRoot().Position - pos.Position).Magnitude
            if dist <= minSharedDist then
                target = v
                minSharedDist = dist 
            end
        end
    end
    if target then
        forceTween(target:IsA("Model") and target:GetModelCFrame() or target.CFrame, nil, false)
        while target.Parent == breakablesFolder do task.wait(0.5) end
        return true
    end
    return false
end

-- Logic 4: Leave System (สั่งเป็น Warp Point เพื่อให้กดย้ำ)
local function runLogic4()
    print("[System] Logic 4: Starting Exit Sequence...")
    task.wait(2)
    local luckyEgg = workspace.__THINGS:FindFirstChild("Instances") and workspace.__THINGS.Instances:FindFirstChild("LuckyEgg")
    
    if luckyEgg and luckyEgg:FindFirstChild("Teleports") then
        local enterPart = luckyEgg.Teleports:FindFirstChild("Enter")
        if enterPart then
            -- ส่ง true เพื่อบอกว่าเป็นจุดวาร์ป ให้กดย้ำถ้าอยู่ใกล้
            forceTween(enterPart.CFrame, nil, true) 
            task.wait(3) 
        end
        local leavePart = luckyEgg.Teleports:FindFirstChild("Leave")
        if leavePart then
            -- ส่ง true เพื่อบอกว่าเป็นจุดวาร์ป ให้กดย้ำถ้าอยู่ใกล้
            forceTween(leavePart.CFrame, Config.LeaveTweenSpeed, true) 
        end
    end
end

local function startBossPhase()
    print("[System] Starting Boss Sequence...")
    local luckyRaid = workspace.__THINGS.__INSTANCE_CONTAINER.Active:FindFirstChild("LuckyRaid")
    for i, bossName in ipairs(Config.BossNames) do
        Network.Raids_BossChallenge:InvokeServer(i)
        if luckyRaid then
            local room = luckyRaid.Rooms:FindFirstChild(bossName)
            local anchor = room and room.BREAK_ZONES:FindFirstChild(bossName)
            if anchor then forceTween(anchor.CFrame, nil, false) task.wait(1) end
        end
        local retry = 0
        while retry < 10 do
            if farmNearestInRoom() then
                task.wait(1.5)
                while collectOrbs() do task.wait(0.1) end
                break
            end
            task.wait(0.5)
            retry = retry + 1
        end
    end
    
    local interactPath = luckyRaid and luckyRaid:FindFirstChild("INTERACT")
    if interactPath then
        for _, chestName in ipairs(Config.Chests) do
            local chest = interactPath:FindFirstChild(chestName)
            if chest then
                forceTween(chest:IsA("Model") and chest:GetModelCFrame() or chest.CFrame, nil, false)
                task.wait(0.5)
                pressE()
                task.wait(2.5) 
                while collectOrbs() do task.wait(0.1) end
            end
        end
    end
    runLogic4()
end

-- [[ MAIN AUTO LOOP ]]
local function main()
    while true do
        local active = workspace.__THINGS.__INSTANCE_CONTAINER:FindFirstChild("Active")
        if active and active:FindFirstChild("LuckyEventWorld") then
            local currentLevel = getRaidLevel()
            local targetPortal = findEmptyPortal()
            if currentLevel and targetPortal then
                Network.Raids_Init:InvokeServer({["Difficulty"] = currentLevel, ["Portal"] = targetPortal, ["PartyMode"] = 1})
                task.wait(Config.WaitBeforeTween)
                local portalsPath = active.LuckyEventWorld.INTERACT.RaidPortals
                -- ส่ง true เพื่อบอกว่าเป็นจุดวาร์ป ให้กดย้ำถ้าอยู่ใกล้ < 20
                forceTween(portalsPath[tostring(targetPortal)].Enter.CFrame, Config.PortalTweenSpeed, true)
                while active:FindFirstChild("LuckyEventWorld") do task.wait(1) end
            end
        elseif active and active:FindFirstChild("LuckyRaid") then
            task.wait(2)
            local idleTime = 0
            while active:FindFirstChild("LuckyRaid") do
                local acted = false
                if collectOrbs() then acted = true end
                local breakablesFolder = workspace.__THINGS:FindFirstChild("Breakables")
                if breakablesFolder then
                    for _, v in pairs(breakablesFolder:GetChildren()) do
                        local pos = v:IsA("Model") and v:GetModelCFrame() or (v:IsA("BasePart") and v.CFrame)
                        if pos and (getRoot().Position - pos.Position).Magnitude <= Config.MaxFarmDistance then
                            forceTween(pos, nil, false)
                            acted = true break
                        end
                    end
                end
                if acted then idleTime = 0 else idleTime = idleTime + 1 end
                if idleTime >= 5 then startBossPhase() break end
                task.wait(1)
            end
        end
        task.wait(2)
    end
end

task.spawn(main)
